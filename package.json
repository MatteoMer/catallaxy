{
  "name": "catallaxy",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "catallaxy": "./bin/catallaxy"
  },
  "scripts": {
    "interface": "bin/catallaxy",
    "watch": "make image-if-needed && bun orchestrator/watch-live.ts",
    "exchange": "bun orchestrator/exchange.ts",
    "ledger": "bun orchestrator/ledger.ts",
    "status": "bun orchestrator/status.ts",
    "memory": "bun orchestrator/memory.ts",
    "trace": "bun orchestrator/trace.ts",
    "pause": "bun orchestrator/pause.ts",
    "create-agent": "bun orchestrator/create-agent.ts",
    "create-task": "bun orchestrator/create-task.ts",
    "pretrain": "make image-if-needed && bun orchestrator/pretrain.ts",
    "pretrain-light": "make image-if-needed && bun orchestrator/pretrain.ts --light",
    "reset": "bun orchestrator/reset.ts",
    "image": "docker/build.sh",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@mariozechner/pi-ai": "0.70.6",
    "@mariozechner/pi-coding-agent": "0.70.6",
    "@mariozechner/pi-tui": "0.70.6",
    "@types/bun": "^1.3.14",
    "typebox": "1.1.38",
    "typescript": "^6.0.3"
  }
}
