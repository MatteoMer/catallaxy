#!/usr/bin/env bun
/**
 * submit — request a review of your work on a task you've been assigned.
 *
 * Usage (from inside an agent sandbox): submit TASK_ID BRANCH
 *
 * Auto-increments the seq number. Writes a review_request file the
 * orchestrator picks up; the reviewer (claude -p) then reads your
 * branch in agents/{your_name}/sandbox/work/{TASK_ID}/.
 *
 * Each call costs `review_fee` tokens (debited when processed).
 */

import { readdir } from "node:fs/promises";

const [, , taskId, branch] = process.argv;
if (!taskId || !branch) {
  console.error("Usage: submit TASK_ID BRANCH");
  process.exit(1);
}

let identity: { name?: string };
try {
  identity = await Bun.file("identity.json").json();
} catch {
  console.error("could not read identity.json from CWD; run this from your sandbox");
  process.exit(1);
}
if (!identity.name) {
  console.error("identity.json missing 'name' field");
  process.exit(1);
}

let existing: string[] = [];
try {
  existing = await readdir("market/review_requests");
} catch {}
const matching = existing.filter(
  (f) => f.startsWith(`${taskId}-${identity.name}-`) && f.endsWith(".json")
);
const seq = matching.length + 1;

const req = {
  task_id: taskId,
  agent: identity.name,
  branch,
  seq,
  requested_at: new Date().toISOString(),
};
const path = `market/review_requests/${taskId}-${identity.name}-${seq}.json`;
await Bun.write(path, JSON.stringify(req, null, 2));
console.log(`review requested: ${taskId} #${seq} branch=${branch}`);
