#!/usr/bin/env bun
/**
 * verdicts — show review verdicts you've received for a task.
 *
 * Usage (from inside an agent sandbox): verdicts TASK_ID
 */

import { readdir } from "node:fs/promises";

const MARKET = `${import.meta.dir}/../market`;

const [, , taskId] = process.argv;
if (!taskId) {
  console.error("Usage: verdicts TASK_ID");
  process.exit(1);
}

let identity: { name?: string };
try {
  identity = await Bun.file("identity.json").json();
} catch {
  console.error("could not read identity.json from CWD");
  process.exit(1);
}
const me = identity.name;
if (!me) {
  console.error("identity.json missing 'name' field");
  process.exit(1);
}

const files = await readdir(`${MARKET}/review_responses`).catch(() => []);
const verdicts: any[] = [];
for (const f of files) {
  if (!f.endsWith(".json")) continue;
  try {
    const r = await Bun.file(`${MARKET}/review_responses/${f}`).json();
    if (r?.task_id === taskId && r?.agent === me) verdicts.push(r);
  } catch {}
}
verdicts.sort((a, b) => (a.seq ?? 0) - (b.seq ?? 0));

if (verdicts.length === 0) {
  console.log(`No verdicts for ${taskId}.`);
  process.exit(0);
}

for (const v of verdicts) {
  console.log(`#${v.seq} — ${v.verdict} (${v.reviewed_at})`);
  console.log(v.feedback);
  console.log();
}
