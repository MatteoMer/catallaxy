#!/usr/bin/env bun
/**
 * task — show full details of a task.
 *
 * Usage: task TASK_ID
 */

const MARKET = `${import.meta.dir}/../market`;

const [, , taskId] = process.argv;
if (!taskId) {
  console.error("Usage: task TASK_ID");
  process.exit(1);
}

let t: any;
try {
  t = await Bun.file(`${MARKET}/tasks/${taskId}.json`).json();
} catch {
  console.error(`task '${taskId}' not found`);
  process.exit(1);
}

console.log(`${t.id} (${t.status})`);
console.log(`description: ${t.description}`);
console.log(`repo: ${t.repo}`);
console.log(`base_branch: ${t.base_branch}`);
console.log(`review_fee: ${t.review_fee}`);
console.log(`deadline_at: ${t.deadline_at}`);
if (Array.isArray(t.deterministic_checks) && t.deterministic_checks.length) {
  console.log(`deterministic_checks:`);
  for (const c of t.deterministic_checks) {
    console.log(`  - ${JSON.stringify(c)}`);
  }
}
if (t.subjective_criteria) console.log(`subjective_criteria: ${t.subjective_criteria}`);
console.log(`posted_by: ${t.posted_by}`);
console.log(`posted_at: ${t.posted_at}`);
