#!/usr/bin/env bun
/**
 * balance — show your current token balance.
 *
 * Usage (from inside an agent sandbox): balance
 */

let b: { balance?: number };
try {
  b = await Bun.file("balance.json").json();
} catch {
  console.error("could not read balance.json from CWD");
  process.exit(1);
}
console.log(b.balance ?? 0);
