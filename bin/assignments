#!/usr/bin/env bun
/**
 * assignments — list tasks you've been assigned (won the auction).
 *
 * Usage (from inside an agent sandbox): assignments
 */

import { readdir } from "node:fs/promises";

const MARKET = `${import.meta.dir}/../market`;

let identity: { name?: string };
try {
  identity = await Bun.file("identity.json").json();
} catch {
  console.error("could not read identity.json from CWD");
  process.exit(1);
}
const me = identity.name;
if (!me) {
  console.error("identity.json missing 'name' field");
  process.exit(1);
}

const files = await readdir(`${MARKET}/assignments`).catch(() => []);
const mine: any[] = [];
for (const f of files) {
  if (!f.endsWith(".json")) continue;
  try {
    const a = await Bun.file(`${MARKET}/assignments/${f}`).json();
    if (a?.winner !== me) continue;
    const t = await Bun.file(`${MARKET}/tasks/${a.task_id}.json`).json().catch(() => null);
    mine.push({ ...a, task_status: t?.status, description: t?.description });
  } catch {}
}

if (mine.length === 0) {
  console.log("No assignments.");
  process.exit(0);
}

console.log("Your assignments:");
for (const a of mine) {
  console.log(`- ${a.task_id} (${a.task_status ?? "?"}) — paid ${a.payment} on LGTM | ${a.description ?? ""}`);
}
console.log();
console.log("Run `task TASK_ID` for full details, `submit TASK_ID BRANCH` after work.");
