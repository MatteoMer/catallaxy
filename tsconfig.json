{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "moduleDetection": "force",
    "lib": ["ES2022", "DOM"],
    "types": ["bun"],
    "allowJs": false,
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true
  },
  "include": [
    "bin/**/*.ts",
    "extensions/**/*.ts",
    "orchestrator/**/*.ts",
    ".pi/extensions/**/*.ts",
    "tests/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "agents",
    "market",
    "repos",
    "dashboard",
    ".catallaxy",
    "orchestrator/private"
  ]
}
